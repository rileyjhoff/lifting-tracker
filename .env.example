# Supabase connection.
# The publishable/anon key is safe to expose to the browser — row-level security
# enforces per-user access. Find these in your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
